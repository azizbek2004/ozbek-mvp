# -----------------------------------------------------------------------------
# Odat Habit Tracker - Environment Variables Template
# -----------------------------------------------------------------------------
# Copy this file to mobile/.env for local development.
# Expo reads environment variables from the mobile app root.

# App deep link scheme (must match native URL scheme)
EXPO_PUBLIC_APP_SCHEME=odat

# Google Sign-In — Web client ID from Firebase Console → Authentication → Google
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Firebase Client Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# EAS Configuration (Optional)
EAS_PROJECT_ID=odat-habit
