{
  "name": "odat-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "build:check": "expo export --platform android --output-dir dist-export-check",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && pod install && xcodebuild -workspace Odat.xcworkspace -scheme Odat -configuration Release -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' build"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@react-native-community/netinfo": "~11.4.0",
    "@react-native-google-signin/google-signin": "^13.2.0",
    "date-fns": "^4.1.0",
    "expo": "~52.0.0",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "~17.0.0",
    "expo-crypto": "~14.0.0",
    "expo-font": "~13.0.0",
    "expo-haptics": "^55.0.14",
    "expo-linking": "~7.0.0",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-sqlite": "~15.1.4",
    "expo-status-bar": "~2.0.0",
    "expo-web-browser": "~14.0.0",
    "firebase": "^10.14.1",
    "i18next": "^24.2.1",
    "react": "18.3.1",
    "react-i18next": "^15.4.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-gifted-charts": "^1.4.46",
    "react-native-mmkv": "^3.2.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "~15.8.0",
    "uuid": "^11.1.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "~18.3.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "typescript": "^5.6.3"
  }
}
